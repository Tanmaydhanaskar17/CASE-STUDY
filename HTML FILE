<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Prime Video Clone</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Navbar -->
<header class="navbar">
  <div class="logo">prime video</div>
  <nav>
    <a href="#">Home</a>
    <a href="#">Movies</a>
    <a href="#">TV Shows</a>
    <a href="#">My Stuff</a>
  </nav>
</header>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-content">
    <h1>Featured Movie</h1>
    <p>Watch the latest blockbuster now</p>
    <button>▶ Play</button>
  </div>
</section>

<!-- Movie Sections -->
<section class="movies-section">
